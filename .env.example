APP_ENV=local
LOG_LEVEL=INFO

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Required when EMBEDDING_BACKEND=openai.
OPENAI_API_KEY=

# Set STORAGE_BACKEND=postgres to use the docker-compose Postgres (D-022).
# The compose image is pgvector/pgvector:pg16 to satisfy D-024.
STORAGE_BACKEND=memory
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=theygrow_diary_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
SQLITE_PATH=./data/diary.db

# Embedding contour (D-024). Defaults: mock backend, text-embedding-3-large, 3072 dim.
# - mock: deterministic in-process stand-in. model_name on persisted rows is the
#         literal "mock" so SQL inspection stays honest.
# - openai: real provider; requires OPENAI_API_KEY. dimensions=3072 is passed
#         explicitly in every request.
EMBEDDING_BACKEND=mock
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072

# Retrieval knobs (D-025 baseline hybrid). retrieval_top_k is the final
# evidence count returned to the answer pipeline; retrieval_candidate_k is the
# per-leg pool size that the dense + sparse legs return into the RRF merge.
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATE_K=20

# Chat contour (Slice 4.5 / D-037). Default: mock backend.
# - mock: deterministic in-process stand-in. model_name on persisted
#         AnswerTrace rows is the literal "mock" so SQL inspection stays honest.
# - openai: real provider; requires OPENAI_API_KEY. Boot aborts unless
#         CHAT_MODEL is the canonical "gpt-4.1" (D-037).
CHAT_BACKEND=mock
CHAT_MODEL=gpt-4.1
