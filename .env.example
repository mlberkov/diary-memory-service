APP_ENV=local
LOG_LEVEL=INFO

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Required when EMBEDDING_BACKEND=openai.
OPENAI_API_KEY=

# Required when KNOWLEDGE_BACKEND=tavily (RC-4, D-108).
TAVILY_API_KEY=

# Set STORAGE_BACKEND=postgres to use the docker-compose Postgres (D-022).
# The compose image is pgvector/pgvector:pg16 to satisfy D-024. POSTGRES_PORT
# is the loopback-only host port for operator/local access; app containers use
# POSTGRES_HOST=postgres on the Compose network and must not expose DB access
# on public interfaces.
STORAGE_BACKEND=memory
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=memory_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
SQLITE_PATH=./data/memory_rag.db

# Backup automation (OP-4.2 / D-054). Consumed by the docker-compose `pg_backup`
# sidecar, which runs only under the `backup` Compose profile
# (`docker compose --profile backup up -d`). The nightly base backup runs once
# per calendar day when the local hour is within
# [BACKUP_WINDOW_START, BACKUP_WINDOW_END); TZ sets that "local" timezone.
# BASE_RETENTION_DAYS bounds base-backup retention; archived WAL is pruned to
# cover the oldest retained base backup.
BACKUP_WINDOW_START=3
BACKUP_WINDOW_END=5
BASE_RETENTION_DAYS=30
TZ=UTC

# Off-box backup sink (DEPLOY-1.6 / D-065). Consumed by the docker-compose
# `pg_offbox_uploader` sidecar, which runs only under the `backup` Compose
# profile (`docker compose --profile backup up -d`) alongside `pg_backup`.
# All five knobs are optional — leave blank to skip off-box upload; the
# uploader logs `pg_backup.offbox.skipped reason=...` and `pg_backup.cycle.ok`
# semantics are unaffected. The installer's `offbox_backup_probe` outcome
# in `.installer-state.json` reports the same skipped/ok/failed verdict.
# - BACKUP_S3_BUCKET: target bucket name (e.g. `my-org-backups`).
# - BACKUP_S3_ENDPOINT: S3-compatible endpoint URL; leave blank for AWS S3,
#   set for R2 / B2 / Wasabi / MinIO (e.g. `https://<acct>.r2.cloudflarestorage.com`).
# - BACKUP_S3_PATH_PREFIX: object prefix under the bucket; defaults to
#   `archive` (artifacts land at `<prefix>/base/...` and `<prefix>/wal/...`).
# - BACKUP_S3_ACCESS_KEY_ID / BACKUP_S3_SECRET_ACCESS_KEY: credentials for
#   the bucket (the operator's secret-management responsibility).
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=
BACKUP_S3_PATH_PREFIX=archive
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=

# Restore drill (OP-4.3 / D-055). Consumed by the docker-compose `pg_restore`
# service, which runs only under the `restore` Compose profile
# (`docker compose --profile restore up -d pg_restore`). RESTORE_PORT is the
# loopback-only host port for the recovered cluster — kept off 5432 so it never
# clashes with the live `postgres` and never opens a recovered cluster to the
# Internet. restore.sh parameters (--backup-dir, --target, ...) are passed on
# the command line via `make restore-plan` / `make restore-run` (see
# docs/RUNBOOK.md "Restore drill").
RESTORE_PORT=5433

# Embedding contour (D-024). Defaults: mock backend, text-embedding-3-large, 3072 dim.
# - mock: deterministic in-process stand-in. model_name on persisted rows is the
#         literal "mock" so SQL inspection stays honest.
# - openai: real provider; requires OPENAI_API_KEY. dimensions=3072 is passed
#         explicitly in every request.
EMBEDDING_BACKEND=mock
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072

# Retrieval knobs (D-025 baseline hybrid). retrieval_top_k is the final
# evidence count returned to the answer pipeline; retrieval_candidate_k is the
# per-leg pool size that the dense + sparse legs return into the RRF merge.
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATE_K=20

# Chat contour (Slice 4.5 / D-037). Default: mock backend.
# - mock: deterministic in-process stand-in. model_name on persisted
#         AnswerTrace rows is the literal "mock" so SQL inspection stays honest.
# - openai: real provider; requires OPENAI_API_KEY. Boot aborts unless
#         CHAT_MODEL is the canonical "gpt-4.1" (D-037).
CHAT_BACKEND=mock
CHAT_MODEL=gpt-4.1

# Provider-call resilience (R-9). Shared by both OpenAI adapters.
# PROVIDER_TIMEOUT_SECONDS is the per-attempt wall-clock budget;
# PROVIDER_MAX_ATTEMPTS is the total attempts including the first (1 disables
# retries). PROVIDER_BACKOFF_BASE_SECONDS / PROVIDER_BACKOFF_CAP_SECONDS size
# the exponential-with-jitter wait between retries — a server Retry-After is
# honored instead when present, also clamped to the cap (D-049). Worst-case
# bounded wall time per provider call is
# TIMEOUT * ATTEMPTS + BACKOFF_CAP * (ATTEMPTS - 1). The mock backends ignore
# all four knobs.
PROVIDER_TIMEOUT_SECONDS=30.0
PROVIDER_MAX_ATTEMPTS=3
PROVIDER_BACKOFF_BASE_SECONDS=0.5
PROVIDER_BACKOFF_CAP_SECONDS=8.0

# DEPLOY-1.3 / D-062 — public reverse-proxy + ACME (Caddy) in front of the
# DEPLOY-1.2 `app` service. Consumed by the docker-compose `caddy` service,
# which runs only under the `vps` Compose profile
# (`docker compose --profile vps up -d --build`).
# - PUBLIC_HOSTNAME: fully-qualified DNS name pointing at the VPS host.
# - ACME_EMAIL: Let's Encrypt registration email.
# Both are required for the public-TLS contour. With either empty / invalid
# the contour does not come up cleanly and there is no HTTP-only fallback.
PUBLIC_HOSTNAME=
ACME_EMAIL=
